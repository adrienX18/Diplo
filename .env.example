# ── Required ──────────────────────────────────────────────────

# Beeper Desktop API token
# Get it from: Beeper Desktop → Settings → Developers → API Access Token
BEEPER_ACCESS_TOKEN=your-beeper-access-token

# Anthropic API key (powers the AI brain)
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# Telegram bot token
# Create a bot via https://t.me/BotFather → /newbot → copy the token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Your Telegram chat ID (restricts the bot to only respond to you)
# Message https://t.me/userinfobot → it replies with your chat ID
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Your name (used in prompts so the AI knows who you are)
USER_NAME=Your Name

# Comma-separated substrings that identify you across messaging platforms
# (lowercase — matched against sender names to detect your own messages)
# Example: if your Beeper ID is @jdoe:beeper.com and your name is "John Doe",
# use: jdoe,john doe
USER_SENDER_IDS=yourusername,your full name

# ── Optional ─────────────────────────────────────────────────

# OpenAI API key (enables voice message transcription + LLM fallback when Claude is down)
# Get it from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key

# Google Calendar (enables schedule queries — "am I free Thursday?")
# See GUIDE.md for setup instructions
# GOOGLE_CALENDAR_CREDENTIALS=email_client_secret.json
# GOOGLE_CALENDAR_TOKEN=google_calendar_token.json

# Email integration (enables Gmail monitoring — "check my email")
# See GUIDE.md for setup instructions
# Comma-separated list of your email addresses (to identify your own emails)
# USER_EMAIL_ADDRESSES=you@gmail.com,you@work.com
